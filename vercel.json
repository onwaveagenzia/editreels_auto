{
  "framework": "nextjs",
  "installCommand": "cd dashboard && npm install",
  "buildCommand": "cd dashboard && npm run build",
  "outputDirectory": "dashboard/.next",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
