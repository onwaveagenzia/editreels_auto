# ONWAVE Environment Configuration
# Copia in .env e compila i valori

# ============================================================================
# API SERVER
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=False
API_PORT=5000
API_HOST=0.0.0.0

# ============================================================================
# GOOGLE DRIVE
# ============================================================================
# Scarica da: https://console.cloud.google.com/
GOOGLE_CREDENTIALS_FILE=~/.onwave/google_credentials.json
GOOGLE_TOKEN_FILE=~/.onwave/google_token.json

# Folder IDs da Google Drive
GOOGLE_DRIVE_INPUT_FOLDER_ID=
GOOGLE_DRIVE_OUTPUT_FOLDER_ID=

# Sync interval (seconds)
GOOGLE_DRIVE_SYNC_INTERVAL=300

# ============================================================================
# ELEVENLABS (Voiceover API)
# ============================================================================
# Prendi da: https://elevenlabs.io/
ELEVENLABS_API_KEY=sk_...

# Default voices
ELEVENLABS_VOICE_PROFESSIONAL=bella
ELEVENLABS_VOICE_WARM=duane
ELEVENLABS_VOICE_ENERGETIC=andrea
ELEVENLABS_VOICE_DEEP=adam

# ============================================================================
# VIDEO PROCESSING
# ============================================================================
# Cartelle di input/output
VIDEO_INPUT_DIR=/tmp/onwave_input
VIDEO_OUTPUT_DIR=/tmp/onwave_output

# FFmpeg path (lascia vuoto per auto-detect)
FFMPEG_PATH=

# Limiti
MAX_VIDEO_SIZE_MB=5000
MAX_CONCURRENT_JOBS=2

# ============================================================================
# DASHBOARD & FRONTEND
# ============================================================================
# URL API (per frontend)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Vercel deployment
VERCEL_ENV=production
VERCEL_URL=

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# DEVELOPMENT
# ============================================================================
# Set to true solo in development
DEBUG=False
ALLOW_LOCALHOST_ONLY=False
